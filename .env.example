PORT=3000

# Gemini AI API Key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeather API Key — https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Main Database — Read-Only
# Connect to the MonuTell monument database (read access only)
POSTGRES_URL=postgres://user:password@host:5432/monutell_db?sslmode=require

# Agent Database — Write Only
# Separate database for photo submissions and AI agent contributions
AGENT_POSTGRES_URL=postgres://user:password@host:5432/monutell_agent_db?sslmode=require

# Admin Panel Password
ADMIN_PASSWORD=your_admin_password_here
